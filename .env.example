# ============================================
# SENTINEL SECURITY SUITE - CONFIGURATION
# ============================================
# Copy this file to .env and configure as needed.
# NEVER commit .env to version control!

# ============================================
# AI PROVIDER (REQUIRED for AI features)
# ============================================
# Groq Cloud API - Get your free API key at: https://console.groq.com/
# Free tier: 30 requests/minute, 14,400/day
GROQ_API_KEY=

# Optional: Override default models
# AI_MODEL_CHAT=llama-3.1-8b-instant
# AI_MODEL_EVENT=llama-3.3-70b-versatile

# ============================================
# EXTERNAL SERVICES (OPTIONAL)
# ============================================

# Sentry crash reporting (OPTIONAL)
# Get DSN from: https://sentry.io/
# Enable structured error tracking and alerting
SENTRY_DSN=

# VirusTotal API Integration (OPTIONAL)
# Get your free API key: https://www.virustotal.com/gui/join-us
# Free tier: 4 requests/minute, 500/day
# Enables: File scanning, URL scanning, threat intelligence
VT_API_KEY=

# Windows Code Signing (OPTIONAL - for release builds)
# Path to code-signing certificate (.pfx or .p12)
WIN_CERT_PATH=

# Windows Certificate Password
WIN_CERT_PASS=

# Network Scanning (OPTIONAL)
# Nmap is auto-detected from system PATH.
# Download from: https://nmap.org/download.html
# Override path only if custom installation:
NMAP_PATH=

# ============================================
# VMware Sandbox Lab (OPTIONAL)
# ============================================
# VMware Workstation vmrun executable
SANDBOX_VMRUN=C:\Program Files (x86)\VMware\VMware Workstation\vmrun.exe

# VMware VMX for the detonation VM
SANDBOX_VMX=D:\vm\windows10\Windows 10 x64.vmx

# Snapshot restored before and after each detonation
SANDBOX_SNAPSHOT=Clean Base

# Guest credentials (required for file/URL detonation)
SANDBOX_GUEST_USER=
SANDBOX_GUEST_PASS=

# Host artifact output
SANDBOX_HOST_RESULTS_DIR=C:\SentinelSandbox\results
SANDBOX_HOST_FRAMES_DIR=C:\SentinelSandbox\frames

# --------------------------------------------
# Offline Mode
# --------------------------------------------
# Set to 'true' to disable ALL external API calls
# (disables VirusTotal and network scanning)
OFFLINE_ONLY=false

# --------------------------------------------
# Advanced Settings (OPTIONAL)
# --------------------------------------------
# Database path (default: ~/.sentinel/sentinel.db)
# DB_PATH=

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Log file path (leave empty for console only)
# LOG_FILE=
